# ------------------------------------------
# Konative environment template
# Copy to .env.local and replace placeholders.
# ------------------------------------------

# Database connection string (required — use one; must start with postgres:// or postgresql://)
# 1) POSTGRES_PRISMA_URL (Neon pooled — good for Vercel serverless)
# 2) DATABASE_URL
# 3) POSTGRES_URL
# 4) DATABASE_URI
# postgres://<user>:<password>@<host>:5432/<database>?sslmode=require
DATABASE_URI=postgres://<user>:<password>@<host>:5432/<database>?sslmode=require

# Payload secret (required, random 32+ chars)
PAYLOAD_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET

# Canonical site URL (required)
NEXT_PUBLIC_SITE_URL=https://konative.com

# Vercel Blob read/write token (required for media uploads)
BLOB_READ_WRITE_TOKEN=REPLACE_WITH_VERCEL_BLOB_RW_TOKEN

# Transactional email (recommended for form notifications)
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_FROM_EMAIL=hello@konative.com

# Optional analytics (Google Tag Manager)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
